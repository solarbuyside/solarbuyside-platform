# Frontend Environment Variables
# Copy this file to .env and configure with your values
# NEVER commit .env to git

# Application
VITE_APP_NAME=Solar Buy Side v2

# Supabase (fonte do conteúdo da LP — landing_sections / landing_globals)
# A landing lê daqui (anon key, leitura pública via RLS) e o /admin da plataforma
# escreve. Mesmos valores do NEXT_PUBLIC_SUPABASE_* da plataforma. A anon key é
# pública por design (vai no bundle). Em produção, setar na Vercel da landing.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API Backend URL
# Production example: https://solarbuyside.com.br/api OR https://api.solarbuyside.com.br
# Development: http://localhost:5000
VITE_API_URL=http://localhost:5000

# Analytics (optional)
VITE_GA_ID=
VITE_HOTJAR_ID=

# Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ADMIN=true
