# Solar Buy-Side API — environment template
# Copy to .env (local) and set in Render dashboard (production).
# NEVER commit .env with real values.

NODE_ENV=production
PORT=5000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=https://solarbuyside.com.br,https://www.solarbuyside.com.br

# MySQL (HostGator)
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT (admin auth)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Brevo (transactional email + contact lists)
# Get key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_NAME=Solar Buy-Side
BREVO_SENDER_EMAIL=contato@solarbuyside.com.br
BREVO_PDF_URL=https://solarbuyside.com.br/assets/Teaser_Codigo_Vendedor_Consultivo.pdf
