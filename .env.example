NEXT_PUBLIC_SUPABASE_URL=https://phuomgqgucrcljwddrmq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_anon_key

# Server-only. Never expose this to the browser.
SUPABASE_SECRET_KEY=replace_with_secret_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin emails (comma-separated). Default: gab.feelix@gmail.com
# ADMIN_EMAILS=

# --- Brevo (email transacional — item 12) ---
# Server-only. NUNCA com prefixo NEXT_PUBLIC_.
# Chave: Brevo -> Settings -> SMTP & API -> API Keys.
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_SENDER_NAME=Solar Buy-Side
BREVO_SENDER_EMAIL=contato@solarbuyside.com.br

# --- Greenn (webhook de compra/reembolso — item 13) ---
# GREENN_WEBHOOK_TOKEN: segredo p/ validar o postback que a Greenn manda.
# GREENN_API_KEY: chave p/ chamarmos a API da Greenn (opcional — validar venda).
GREENN_WEBHOOK_TOKEN=replace_with_greenn_webhook_token
GREENN_API_KEY=replace_with_greenn_api_key
GREENN_PUBLIC_KEY=replace_with_greenn_public_key

# Legacy/local aliases accepted by src/lib/env.ts:
# Project_URL_SUPABASE=https://phuomgqgucrcljwddrmq.supabase.co
# PUBLISHABLE_KEY_SUPABASE=replace_with_publishable_key
# SECRET_KEYS_SUPABASE=replace_with_secret_key
# ANON_PUBLIC_SUPABASE=replace_with_anon_key
# SERVICE_ROLE_SUPABASE=replace_with_service_role_key
